{
  "name": "noita-util",
  "version": "2.0.0",
  "private": true,
  "description": "Noita Save File Utilities",
  "homepage": "https://github.com/jalbarrang/noita-util",
  "license": "MIT",
  "author": "Juan Albarran <jalbarrandev@gmail.com>",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "lint": "oxlint",
    "format": "oxfmt",
    "generate-routes": "tsr generate",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "test": "vitest run",
    "build": "bun run typecheck && electron-vite build",
    "build:unpack": "bun run build && electron-builder --dir",
    "build:win": "bun run build && electron-builder --win"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-router": "^1.168.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "fast-xml-parser": "^5.7.2",
    "lucide-react": "^1.11.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-resizable-panels": "^4.10.0",
    "sonner": "^2.0.7",
    "systeminformation": "^5.31.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "yauzl": "^3.3.0",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/router-cli": "^1.166.36",
    "@tanstack/router-plugin": "^1.167.27",
    "@types/bun": "^1.3.13",
    "@types/node": "24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^3.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "bun@1.3.13"
}
